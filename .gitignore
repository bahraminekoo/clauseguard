# ClauseGuard – project-wide ignore rules

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python / Backend (FastAPI, LangGraph, FAISS)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checking & linting
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/

# -----------------------------------------------------------------------------
# FAISS / embeddings (generated indices – regenerate from source)
# -----------------------------------------------------------------------------
*.faiss
*.index

# -----------------------------------------------------------------------------
# Node / Frontend (Next.js, TypeScript, Tailwind)
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# OS & IDE
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# -----------------------------------------------------------------------------
# Docker (optional local overrides)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.env.docker

# -----------------------------------------------------------------------------
# Local / dev
# -----------------------------------------------------------------------------
*.local
uploads/
tmp/
temp/
