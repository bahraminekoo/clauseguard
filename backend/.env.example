
APP_NAME=ClauseGuard API
ENVIRONMENT=local
CORS_ALLOW_ORIGINS=http://localhost:3000

# Provider selection: "ollama" or "openrouter"
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when provider=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenRouter settings (used when provider=openrouter)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
