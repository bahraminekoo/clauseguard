
APP_NAME=ClauseGuard API
ENVIRONMENT=local
CORS_ALLOW_ORIGINS=http://localhost:3000

# Provider selection: "ollama", "openrouter", or "huggingface"
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when provider=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenRouter settings (used when provider=openrouter)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Hugging Face settings (used when provider=huggingface)
HF_API_KEY=hf_your-token-here
HF_LLM_BASE_URL=https://router.huggingface.co/v1
HF_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
HF_EMBEDDING_BASE_URL=https://router.huggingface.co/hf-inference
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
